// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  authId          String    @unique // Supabase auth.users.id
  themePreference String    @default("dark")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId     String
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  plan      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  studios   Studio[]
}

model Studio {
  id           String          @id @default(cuid())
  workspaceId  String
  rootDomain   String
  submittedUrl String
  displayName  String?
  status       String          @default("pending")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  workspace    Workspace       @relation(fields: [workspaceId], references: [id])
  profile      StudioProfile?
  brandAssets  BrandAsset[]
  jobs         GenerationJob[]
  generations  Generation[]
  assets       Asset[]
  presets      Preset[]
}

model StudioProfile {
  id              String   @id @default(cuid())
  studioId        String   @unique
  version         Int      @default(1)
  colors          Json
  fonts           Json
  logos           Json
  styleTraits     String[]
  provenance      Json
  brandName       String?
  tagline         String?
  description     String?
  aestheticDesc   String?
  toneKeywords    String[]  @default([])
  isConfirmed     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  studio          Studio    @relation(fields: [studioId], references: [id])
}

model BrandAsset {
  id         String   @id @default(cuid())
  studioId   String
  type       String
  storageKey String
  metadata   Json?
  sourceUrl  String?
  createdAt  DateTime @default(now())
  studio     Studio   @relation(fields: [studioId], references: [id])
}

model GenerationJob {
  id         String   @id @default(cuid())
  jobType    String
  status     String   @default("queued")
  stage      String?
  studioId   String?
  payload    Json?
  progress   Int      @default(0)
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  studio     Studio?  @relation(fields: [studioId], references: [id])
}

model Generation {
  id          String   @id @default(cuid())
  studioId    String
  prompt      String
  parameters  Json
  status      String   @default("queued")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  studio      Studio   @relation(fields: [studioId], references: [id])
  assets      Asset[]
}

model Asset {
  id            String      @id @default(cuid())
  studioId      String
  generationId  String?
  type          String
  storageKey    String
  url           String?
  prompt        String?
  parameters    Json?
  metadata      Json?
  isFavorite    Boolean     @default(false)
  isReference   Boolean     @default(false)
  createdAt     DateTime    @default(now())
  studio        Studio      @relation(fields: [studioId], references: [id])
  generation    Generation? @relation(fields: [generationId], references: [id])
}

model Preset {
  id         String   @id @default(cuid())
  studioId   String
  name       String
  parameters Json
  createdAt  DateTime @default(now())
  studio     Studio   @relation(fields: [studioId], references: [id])
}
